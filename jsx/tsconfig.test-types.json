{
    "extends": "./tsconfig.json",
    "include": ["src", "tests"],
    "compilerOptions": {
        "jsx": "react-jsx",
        "jsxImportSource": "@slimlib/jsx",
        "noEmit": true,
        "composite": false,
        "paths": {
            "@slimlib/jsx": ["./src/index.ts"],
            "@slimlib/jsx/jsx-runtime": ["./src/jsx-runtime.ts"],
            "@slimlib/jsx/for-each": ["./src/for-each.ts"]
        }
    }
}
